---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="My Backlog"
  description="Your local-first game backlog — the queue of what's next, the games you're playing now, and everything you've finished or dropped."
>
  <main id="main" tabindex="-1" class="mx-auto max-w-3xl px-5 py-10 sm:py-16">
    <p class="kicker">Your library</p>
    <h1 class="mt-3 text-3xl sm:text-4xl">My Backlog</h1>
    <p class="mt-4 max-w-prose text-base leading-relaxed text-ink-dim">
      Your tracker lives here. Soon this page will hold your queue, the games
      you're playing now, and your completed history — all stored locally on
      this device.
    </p>
  </main>
</BaseLayout>
