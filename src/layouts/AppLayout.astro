---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  /** Document title shown in the browser tab. */
  title: string;
}

const { title } = Astro.props;

/* Placeholder destinations until the tracker views exist. */
const navLinks = [
  { label: "Playing", href: "#" },
  { label: "Backlog", href: "#" },
  { label: "History", href: "#" },
] as const;
---

<BaseLayout title={title}>
  <header class="sticky top-0 z-40 border-b border-line bg-bg">
    <div
      class="mx-auto flex max-w-3xl items-center justify-between px-5 py-3"
    >
      <a
        href="/app"
        class="inline-flex min-h-11 items-center gap-2 text-ink no-underline"
      >
        <span
          class="inline-block h-2.5 w-2.5 rounded-full bg-accent"
          aria-hidden="true"></span>
        <span class="font-medium">Backlog</span>
      </a>
      <nav aria-label="Main navigation">
        <ul class="flex items-center gap-1 sm:gap-2">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="inline-flex min-h-11 items-center px-2 text-sm text-ink-dim hover:text-ink sm:px-3"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </header>

  <slot />
</BaseLayout>
